{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://email-triage.local/schema/email-triage.schema.json",
  "title": "EmailTriageDecision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "triage",
    "priority",
    "risk",
    "should_process",
    "confidence",
    "reason"
  ],
  "properties": {
    "triage": {
      "type": "string",
      "enum": ["reply", "archive", "escalate", "ignore", "review"]
    },
    "priority": {
      "type": "string",
      "enum": ["low", "normal", "high", "critical"]
    },
    "risk": {
      "type": "string",
      "enum": [
        "none",
        "spam",
        "phishing",
        "prompt_attack",
        "credential_request",
        "malware",
        "suspicious"
      ]
    },
    "should_process": {
      "type": "boolean"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "reason": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    }
  }
}

